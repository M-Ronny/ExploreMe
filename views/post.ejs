<section class="post">
  <img class="postImg" src="<%= post.image%>" alt="post" />
  <div class="buttons">
    <form
      class="col-1"
      action="/post/likePost/<%= post.id %>?_method=PUT"
      method="POST"
    >
      <button class="btn btn-square fa fa-heart" type="submit"></button>
      <h3 class="col-3">Likes: <%= post.likes %></h3>
    </form>
    <% if (user.bookmarks.includes(post.id)) { %>
      <form
        class="col-1"
        action="/post/removeBookmark/<%= post.id %>?_method=PUT"
        method="POST"
      >
        <button class="btn btn-square fa fa-bookmark" type="submit"></button>
      </form>
    <%} else { %>
      <form
        class="col-1"
        action="/post/bookmarkPost/<%= post.id %>?_method=PUT"
        method="POST"
      >
        <button class="btn btn-square fa fa-bookmark" type="submit"></button>
      </form>
    <%}%>
    <%if(post.user == user.id){ %>
      <form
        action="/post/deletePost/<%= post.id %>?_method=DELETE"
        method="POST"
        class="col-3"
      >
        <button class="btn btn-square fa fa-trash" type="submit"></button>
      </form>
    <%}%>
  </div>
  <!-- <div class="card-body"> -->
    <div class="experience">
      <h2 class="name card-title"><%= post.name %></h2>
      <h3 class="location">Location: <%= post.location %></h3>
      <p><%= post.experience %></p>
    </div>
  <!-- </div> -->
</section>

<%- include('partials/footer') -%>