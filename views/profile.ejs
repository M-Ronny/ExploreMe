<section class="user">
  <p><strong>User Name</strong>: <%= user.userName %></p>
  <p><strong>Email</strong>: <%= user.email %></p>
</section>

<section class="profile">
  <div class="createPost">
    <form action="/post/createPost" enctype="multipart/form-data" method="POST">
      <fieldset class="fieldset bg-base-200 border-base-300 rounded-box w-xs border p-4">
        <legend class="fieldset-legend">Tell us about your experience</legend>

        <label for="name" class="label">Name of the Place</label>
        <input type="text" class="input" id="name" name="name" placeholder="Name" />

        <label for="location" class="label">Location</label>
        <input type="text" class="input" id="location" name="location" placeholder="Location" />

        <label for="experience" class="label">Your Experience</label>
        <textarea class="textarea" id="experience" name="experience" placeholder="Your Experience"></textarea>

        <label for="imgUpload" class="label">Image</label>
        <input type="file" class="file-input" id="imageUpload" name="file" multiple/>

        <button type="submit" class="btn btn-neutral mt-4" value="Upload">Submit</button>
      </fieldset>
    </form>
  </div>  

  <div class="posts">
    <% for(var i=0; i<posts.length; i++) {%>
      <div class="card bg-base-100 w-96 shadow-sm">
        <a href="/post/<%= posts[i]._id%>">
        <figure>
          <img
            src="<%= posts[i].image%>"
            alt="post" />
        </figure>
        <div class="card-body">
          <h2 class="card-title"><%= posts[i].name%></h2>
        </div>
        </a> 
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') -%>