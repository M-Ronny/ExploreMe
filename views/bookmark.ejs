<section class="allPosts">
  <% for(var i=0; i<post.length; i++) {%>
    <div class="card bg-base-100 w-96 shadow-sm">
      <a href="/post/<%= post[i]._id%>">
        <figure>
          <img
            src="<%= post[i].image%>"
            alt="post" />
        </figure>
        <div class="card-body">
          <h2 class="card-title"><%= post[i].name%></h2>
        </div>
      </a> 
    </div>
  <% } %> 
</section>  

